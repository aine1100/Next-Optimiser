{
  "name": "next-optimize",
  "version": "1.0.0",
  "description": "Enterprise-ready performance optimization engine for React and Next.js",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "next-optimize": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./agent": "./dist/agent/agent.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc && node scripts/build-agent.mjs",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "cd docs/mintlify && npx mintlify dev"
  },
  "keywords": [
    "performance",
    "optimization",
    "react",
    "nextjs",
    "cli"
  ],
  "author": "Aine",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "esbuild": "^0.20.1",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "ora": "^8.0.1",
    "ts-morph": "^21.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.11.24",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}